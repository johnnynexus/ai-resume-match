# Production env for the Next.js web app (Vercel).
# Set these as Vercel project environment variables — do NOT commit real values.
# See README "Deployment".

# The deployed Fly.io API URL. API_URL is used by the server-side BFF routes
# (the one that actually matters); NEXT_PUBLIC_API_URL is exposed to the client.
API_URL=https://resumematch-api.fly.dev
NEXT_PUBLIC_API_URL=https://resumematch-api.fly.dev

# Shared secret with the API — MUST match the API's INTERNAL_API_SECRET exactly
# (set via `fly secrets set`), or analyses fail with 401.
# Generate once: openssl rand -base64 32
INTERNAL_API_SECRET=

# Neon Postgres (production) — sign-in user upsert + history reads. Use the same
# database as the API.
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# --- Auth.js ---
# Generate: openssl rand -base64 32
AUTH_SECRET=

# Google OAuth (production). In Google Cloud Console, add the redirect URI:
#   https://your-app.vercel.app/api/auth/callback/google
# and the authorized origin: https://your-app.vercel.app
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Leave AUTH_TEST_MODE unset in production (it enables a password-less login).
