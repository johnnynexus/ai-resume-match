# URL of the Fastify API (used by Next.js BFF routes to proxy requests).
API_URL=http://localhost:8080

# Also exposed for any client-side references (BFF is preferred for API calls).
NEXT_PUBLIC_API_URL=http://localhost:8080

# Shared secret between the Next.js BFF and the Fastify API.
# Generate with: openssl rand -base64 32
INTERNAL_API_SECRET=replace-me-with-a-long-random-string

# Neon Postgres — required for sign-in (user upsert) and analysis persistence.
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# --- Auth.js ---
# Generate with: openssl rand -base64 32
AUTH_SECRET=replace-me

# Google OAuth — create at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Enable a test Credentials provider for Playwright (never in production).
# AUTH_TEST_MODE=true
