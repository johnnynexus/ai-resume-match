# URL of the Fastify API (the Railway/Render/Fly deployment, or local dev).
NEXT_PUBLIC_API_URL=http://localhost:8080

# --- Auth.js (NextAuth) — wired up when auth lands. ---
# Generate with: openssl rand -base64 32
AUTH_SECRET=replace-me
# Add provider credentials here, e.g.:
# AUTH_GITHUB_ID=
# AUTH_GITHUB_SECRET=
