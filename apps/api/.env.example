# --- Required ---
# Anthropic API key. Lives ONLY here, server-side — never in the frontend.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# --- Optional ---
# Neon Postgres connection string. If unset, the API runs without caching or
# persistence (the Claude core still works end-to-end).
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Port the API listens on.
PORT=8080

# Allowed CORS origin(s) — the Vercel frontend URL. Comma-separate for multiple.
# If unset: all origins allowed in development, none in production.
ALLOWED_ORIGIN=http://localhost:3000

# Override the Claude model (defaults to claude-sonnet-4-6 per CLAUDE.md).
# ANTHROPIC_MODEL=claude-sonnet-4-6
