# --- Required (Gemini — default provider) ---
# Google AI API key. Lives ONLY here, server-side — never in the frontend.
GEMINI_API_KEY=your-gemini-api-key

# --- Optional ---
# LLM provider: gemini (default) or claude.
# LLM_PROVIDER=gemini

# Override the model (defaults: gemini-2.5-flash / claude-sonnet-4-6).
# LLM_MODEL=gemini-2.5-flash

# --- Claude (only when LLM_PROVIDER=claude) ---
# ANTHROPIC_API_KEY=sk-ant-...


# Neon Postgres connection string. If unset, the API runs without caching or
# persistence (the LLM core still works end-to-end).
# DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require


# Port the API listens on.
PORT=8080

# Allowed CORS origin(s) — the Vercel frontend URL. Comma-separate for multiple.
# If unset: all origins allowed in development, none in production.
ALLOWED_ORIGIN=http://localhost:3000

# Shared secret between the Next.js BFF and this API (must match apps/web).
# When set, /api/analyze requires x-internal-auth + x-user-id headers.
# Generate with: openssl rand -base64 32
INTERNAL_API_SECRET=replace-me-with-a-long-random-string
