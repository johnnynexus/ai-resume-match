# Production env for the Fastify API (Railway).
# Set these as Railway service variables — do NOT commit real values.
# See README "Deployment".

# --- Required ---
# Google AI (Gemini) API key. Server-side only, never shipped to the client.
GEMINI_API_KEY=

# Neon Postgres (production). Prefer a dedicated prod database/branch, separate
# from local dev. Migrations are applied automatically via railway.json's
# preDeployCommand (prisma migrate deploy).
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Shared secret with the web app — MUST be byte-for-byte identical to the value
# set in Vercel, or /api/analyze rejects the BFF with 401. Generate once:
#   openssl rand -base64 32
INTERNAL_API_SECRET=

# The deployed Vercel URL, for CORS. Comma-separate for multiple origins.
ALLOWED_ORIGIN=https://your-app.vercel.app

# --- Optional ---
# LLM_PROVIDER=gemini
# LLM_MODEL=gemini-2.5-flash
# Railway injects PORT automatically and the API reads it — leave unset.
# PORT=8080

# --- Claude (only when LLM_PROVIDER=claude) ---
# ANTHROPIC_API_KEY=
