# Production env for the Fastify API (Fly.io).
# Set these as Fly secrets — do NOT commit real values:
#   fly secrets set GEMINI_API_KEY=... DATABASE_URL=... INTERNAL_API_SECRET=...
# See README "Deployment".

# --- Required ---
# Google AI (Gemini) API key. Server-side only, never shipped to the client.
GEMINI_API_KEY=

# Neon Postgres (production). Prefer a dedicated prod database/branch, separate
# from local dev. Migrations are applied automatically via fly.toml's
# [deploy] release_command (prisma migrate deploy).
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Shared secret with the web app — MUST be byte-for-byte identical to the value
# set in Vercel, or /api/analyze rejects the BFF with 401. Generate once:
#   openssl rand -base64 32
INTERNAL_API_SECRET=

# The deployed Vercel URL, for CORS. Comma-separate for multiple origins.
ALLOWED_ORIGIN=https://your-app.vercel.app

# --- Optional ---
# LLM_PROVIDER=gemini
# LLM_MODEL=gemini-2.5-flash
# PORT is set in fly.toml ([env] PORT="8080") to match internal_port — no need
# to set it here.
# PORT=8080

# --- Claude (only when LLM_PROVIDER=claude) ---
# ANTHROPIC_API_KEY=
